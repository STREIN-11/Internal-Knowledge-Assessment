# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no extra setup needed)
DATABASE_URL=sqlite:///./knowledge_assistant.db

# ── LLM (Option 2: OpenAI) ────────────────────────────────────────────────────
# Leave blank to use extractive fallback (Option 3)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
